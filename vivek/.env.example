# =============================================================================
# Adaptive Presentation Engine — Environment template
# Copy to .env and fill in your API keys. Never commit .env to git.
# =============================================================================

# OpenAI-compatible API (optional if using Claude only)
# Used when LLM_MODE=openai_compat or when BASELINE_LLM_MODE/ADAPTIVE_LLM_MODE
# is set to openai_compat. Works with OpenAI, Groq, or any chat/completions API.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1

# Primary LLM mode: "anthropic" (Claude) or "openai_compat" (OpenAI/Groq).
LLM_MODE=anthropic

# Anthropic Claude API — used when mode is "anthropic".
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Per-endpoint overrides. /api/chat_plain uses BASELINE_LLM_MODE;
# /api/chat uses ADAPTIVE_LLM_MODE. Leave unset to inherit LLM_MODE.
BASELINE_LLM_MODE=anthropic
ADAPTIVE_LLM_MODE=anthropic

# Combined response+widget generation limits (Claude single-call flow).
COMBINED_TIMEOUT_SECONDS=90
COMBINED_MAX_TOKENS=4500

# Anthropic fast mode: enables faster inference via beta header.
ANTHROPIC_FAST_MODE_ENABLED=1

# Widget output format: "html" (full HTML in iframe) or "json" (UI schema).
WIDGET_MODE=html
